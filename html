                    <button class="btn">Add to Cart</button>
                </div>
            </div>
            <div class="product-card" data-name="Casual Blouse" data-price="8000">
                <div class="product-image"><img src="https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?auto=format&fit=crop&w=800&q=80" alt="Casual Blouse"></div>
                <div class="product-info">
                    <h3>Casual Blouse</h3>
                    <p class="product-price">₦8,000</p>
                    <button class="btn">Add to Cart</button>
                </div>
            </div>
            <div class="product-card" data-name="Formal Suit" data-price="25000">
                <div class="product-image"><img src="https://images.unsplash.com/photo-1514996937319-344454492b37?auto=format&fit=crop&w=800&q=80" alt="Formal Suit"></div>
                <div class="product-info">
                    <h3>Formal Suit</h3>
