                <div class="product-info">
                    <h3>Stylish Shirt</h3>
                    <p class="product-price">₦10,000</p>
                    <button class="btn">Add to Cart</button>
                </div>
            </div>
            <div class="product-card" data-name="Elegant Pants" data-price="12000">
                <div class="product-image"><img src="https://images.unsplash.com/photo-1521334884684-d80222895322?auto=format&fit=crop&w=800&q=80" alt="Elegant Pants"></div>
                <div class="product-info">
                    <h3>Elegant Pants</h3>
                    <p class="product-price">₦12,000</p>
                    <button class="btn">Add to Cart</button>
                </div>
            </div>
            <div class="product-card" data-name="Chic Jacket" data-price="20000">
                <div class="product-image"><img src="https://images.unsplash.com/photo-1495121605193-b116b5b09a89?auto=format&fit=crop&w=800&q=80" alt="Chic Jacket"></div>
                <div class="product-info">
